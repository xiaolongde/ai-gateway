# 复制为 .env 后填真实值。.env 已被 .gitignore，不会进 git。

# === LiteLLM 自身 ===
# Master key：客户端调用网关时用的认证 key（自己设强随机即可）
LITELLM_MASTER_KEY=sk-litellm-CHANGE_ME

# Salt key：用于加密存储到 DB 的上游 key 等敏感字段
LITELLM_SALT_KEY=CHANGE_ME_random_salt

# === M1.5 admin UI / Postgres / 朋友 virtual key ===
# Postgres 密码（compose stack 起 Postgres container 用）
POSTGRES_PASSWORD=CHANGE_ME_strong_pg_password

# Admin UI login（: 4000/ui）
UI_USERNAME=admin
UI_PASSWORD=CHANGE_ME_strong_admin_password

# === 上游 routing ===
# copilot-api endpoint。docker-compose 用 service DNS；裸机 venv 用 127.0.0.1
COPILOT_API_BASE=http://copilot-api:4141
# 裸机模式改成: COPILOT_API_BASE=http://127.0.0.1:4141

# === 上游 API key（按需填，没填的家不可用） ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# === copilot-api 出网代理（仅当宿主机需要走 Clash 等代理才填） ===
# Docker Desktop 上：宿主 Clash 在 :7897，container 走 host.docker.internal
# COPILOT_HTTP_PROXY=http://host.docker.internal:7897
# COPILOT_HTTPS_PROXY=http://host.docker.internal:7897
# Linux VPS 海外：留空
COPILOT_HTTP_PROXY=
COPILOT_HTTPS_PROXY=

# === Python UTF-8（CN Windows 防 GBK 解码挂） ===
PYTHONUTF8=1
PYTHONIOENCODING=utf-8
