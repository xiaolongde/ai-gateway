# 复制为 .env 后填真实值。.env 已被 .gitignore，不会进 git。

# === LiteLLM 自身 ===
# Master key：客户端调用网关时用的认证 key（自己设强随机即可）
LITELLM_MASTER_KEY=sk-litellm-CHANGE_ME

# Salt key：用于加密存储的上游 key（如启用 DB 模式，本地自用可任意串）
LITELLM_SALT_KEY=CHANGE_ME_random_salt

# === 上游 API key（按需填写，没填的家不可用） ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
